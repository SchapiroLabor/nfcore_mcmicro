nextflow_workflow {

    name "Test Workflow PIPELINE_INITIALISATION"
    script "../main.nf"
    workflow "PIPELINE_INITIALISATION"

    [

        test("Should accept spaces in marker_sheet content (ticket #22)") {
            when {
                params {
                    input_cycle = "${projectDir}/assets/samplesheet-test.csv"
                    marker_sheet = "${projectDir}/assets/markers_1_sp.csv"
                }
                workflow {
                    """
                    input = [false, false, false, [], '$outputDir', params.input_cycle, [], params.marker_sheet]
                    """
                }
            }
            then {
                assert workflow.success
            }

        },

        test("Error on tma_dearray without pixel_size") {
            when {
                params {
                    input_cycle = "${projectDir}/assets/samplesheet-test.csv"
                    marker_sheet = "${projectDir}/assets/markers_1_sp.csv"
                    tma_dearray = true

                }
                workflow {
                    """
                    input = [false, false, false, [], '$outputDir', params.input_cycle, [], params.marker_sheet]
                    """
                }
            }
            then {
                assert workflow.failed
                assert workflow.stdout*.contains("pixel_size").any()
            }
        },
        test("Error on backsub if backsub true, but columns not provided") {
            when {
                params {
                    input_cycle = "${projectDir}/assets/samplesheet-test.csv"
                    marker_sheet = "${projectDir}/assets/markers-test.csv"
                    backsub = true

                }
                workflow {
                    """
                    input = [false, false, false, [], '$outputDir', params.input_cycle, [], params.marker_sheet]
                    """
                }
            }
            then {
                assert workflow.failed
                assert workflow.stdout*.contains("set params.backsub=false").any()
            }
        },
        // test("Error on backsub if columns are provided, but backsub is false") {
        //     when {
        //         params {
        //             input_cycle = "${projectDir}/assets/samplesheet-test.csv"
        //             marker_sheet = "${projectDir}/assets/markers-test_backsub.csv"

        //         }
        //         workflow {
        //             """
        //             input = [false, false, false, [], '$outputDir', params.input_cycle, [], params.marker_sheet]
        //             """
        //         }
        //     }
        //     then {
        //         assert workflow.failed
        //         assert workflow.stdout*.contains("Either remove these columns or set params.backsub to true.").any()
        //     }
        // },
        test("Error on backsub if background value not in marker_name") {
            when {
                params {
                    input_cycle = "${projectDir}/assets/samplesheet-test.csv"
                    marker_sheet = "${projectDir}/assets/markers-test_backsub_f.csv"
                    backsub = true

                }
                workflow {
                    """
                    input = [false, false, false, [], '$outputDir', params.input_cycle, [], params.marker_sheet]
                    """
                }
            }
            then {
                assert workflow.failed
                assert workflow.stdout*.contains("does not exist in the marker_name column.").any()
            }
        },
        test("Error on backsub if exposure time missing") {
            when {
                params {
                    input_cycle = "${projectDir}/assets/samplesheet-test.csv"
                    marker_sheet = "${projectDir}/assets/markers-test_backsub_f2.csv"
                    backsub = true

                }
                workflow {
                    """
                    input = [false, false, false, [], '$outputDir', params.input_cycle, [], params.marker_sheet]
                    """
                }
            }
            then {
                assert workflow.failed
                assert workflow.stdout*.contains("does not have an exposure value.").any()
            }
        },

    ]
}
