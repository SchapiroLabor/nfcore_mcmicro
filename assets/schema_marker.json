{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/mcmicro/master/assets/schema_marker.json",
    "title": "nf-core/mcmicro pipeline - params.marker_sheet schema",
    "description": "Schema for the file provided with params.marker_sheet",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "channel_number": {
                "type": "integer",
                "minimum": 1,
                "errorMessage": "channel_number must be provided"
            },
            "cycle_number": {
                "type": "integer",
                "minimum": 1,
                "errorMessage": "cycle_number must be provided"
            },
            "marker_name": {
                "type": "string",
                "pattern": "\\S",
                "errorMessage": "marker_name must be provided"
            },
            "filter": {
                "type": "string",
                "pattern": "\\S",
                "errorMessage": ""
            },
            "excitation_wavelength": {
                "type": "integer",
                "errorMessage": ""
            },
            "emission_wavelength": {
                "type": "integer",
                "errorMessage": ""
            },
            "exposure": {
                "type": "number",
                "minimum": 0.001,
                "errorMessage": "Exposure time must be a positive number."
            },
            "background": {
                "type": "string"
            },
            "remove": {
                "type": "boolean"
            },
            "segmentation_channel": {
                "type": "boolean"
            },
            "segmentation_compartment": {
                "type": "string",
                "pattern": "^(nucleus|cytoplasm|membrane)$"
            }
        },
        "required": ["channel_number", "cycle_number", "marker_name"]
    }
}
